{
  "title": "Koffing Air Quality",
  "uid": "koffing-air-quality",
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "PM2.5 (µg/m³)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb-koffing" },
      "targets": [{
        "query": "SELECT time, pm25 FROM air_quality WHERE $timeFilter",
        "rawQuery": true,
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 12, "color": "yellow" },
              { "value": 35, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      }
    },
    {
      "id": 2,
      "title": "CO2 (ppm)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "influxdb-koffing" },
      "targets": [{
        "query": "SELECT time, co2 FROM air_quality WHERE $timeFilter",
        "rawQuery": true,
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 800, "color": "yellow" },
              { "value": 1500, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      }
    },
    {
      "id": 3,
      "title": "VOC Index",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-koffing" },
      "targets": [{
        "query": "SELECT time, voc FROM air_quality WHERE $timeFilter",
        "rawQuery": true,
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 100, "color": "yellow" },
              { "value": 250, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      }
    },
    {
      "id": 6,
      "title": "Gas (raw ADC)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "influxdb-koffing" },
      "targets": [{
        "query": "SELECT time, gas FROM air_quality WHERE $timeFilter",
        "rawQuery": true,
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 300, "color": "yellow" },
              { "value": 800, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      }
    },
    {
      "id": 4,
      "title": "Temperature (°F)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "influxdb", "uid": "influxdb-koffing" },
      "targets": [{
        "query": "SELECT time, temp_f FROM air_quality WHERE $timeFilter",
        "rawQuery": true,
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 5,
      "title": "Humidity (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "influxdb", "uid": "influxdb-koffing" },
      "targets": [{
        "query": "SELECT time, humidity FROM air_quality WHERE $timeFilter",
        "rawQuery": true,
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      }
    }
  ]
}
